# REQUIRED: Secret key for JWT token signing (generate a strong random string)
JWT_SECRET=change-this-to-a-random-string

# REQUIRED: Google reCAPTCHA v3 keys (get from https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# REQUIRED: Encryption key for PII fields (phone, email)
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# OPTIONAL: Database URL (default: sqlite:///./flowpoint.db)
DATABASE_URL=sqlite:///./flowpoint.db

# OPTIONAL: CORS origins (comma-separated, default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# OPTIONAL: WhatsApp number and contact email
WHATSAPP_NUMBER=+917670976226
CONTACT_EMAIL=agoaqua99@gmail.com

# OPTIONAL: Log level (default: INFO)
LOG_LEVEL=INFO

# OPTIONAL: JWT expiry in minutes (default: 1440 = 24 hours)
JWT_EXPIRY_MINUTES=1440

# OPTIONAL: Frontend reCAPTCHA site key (used by client-side reCAPTCHA script)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
